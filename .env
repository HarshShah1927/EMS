# MongoDB Atlas Configuration
VITE_MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/employee_management?retryWrites=true&w=majority

# Application Configuration
VITE_APP_NAME=Employee Management System
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Security Configuration
VITE_JWT_SECRET=your-super-secret-jwt-key-here
VITE_BCRYPT_ROUNDS=12

# Email Configuration (Optional)
VITE_EMAIL_SERVICE=gmail
VITE_EMAIL_USER=your-email@gmail.com
VITE_EMAIL_PASS=your-app-password